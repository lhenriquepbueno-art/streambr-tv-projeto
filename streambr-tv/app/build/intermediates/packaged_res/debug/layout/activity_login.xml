<?xml version="1.0" encoding="utf-8"?>
<!--
    LoginActivity — tela de login para TV/Firestick

    Layout em duas colunas (landscape obrigatório em TV):
      Esquerda (40%): branding — logo + tagline
      Direita (60%):  formulário — URL servidor, usuário, senha, botão

    Campos grandes (mínimo 56dp de altura) para fácil navegação com D-pad.
    Ordem de foco D-pad: servidor → usuário → senha → botão login
    nextFocusDown / nextFocusUp garantem a ordem correta.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/background_dark">

    <!-- ── Painel esquerdo: Branding ──────────────────────────────────── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.42"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/background_surface"
        android:padding="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STREAM\nBR"
            android:textSize="64sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.1"
            android:lineSpacingMultiplier="0.85"
            android:gravity="center_horizontal"
            android:fontFamily="sans-serif-condensed"/>

        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:background="@color/accent_red"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Canais ao vivo • VOD • Esportes"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Android TV · Fire TV Stick"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="8dp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- ── Painel direito: Formulário ─────────────────────────────────── -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.58"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:padding="56dp"
            android:minHeight="400dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entrar na sua conta"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Use o controle remoto para navegar entre os campos"
                android:textSize="13sp"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="36dp"/>

            <!-- Campo: URL do servidor -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="URL do servidor"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/et_server_url"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="http://192.168.1.100:3000"
                android:inputType="textUri"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_hint"
                android:background="@drawable/bg_input_field"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:maxLines="1"
                android:imeOptions="actionNext"
                android:nextFocusDown="@+id/et_username"
                android:focusable="true"/>

            <Space android:layout_width="match_parent" android:layout_height="16dp"/>

            <!-- Campo: Usuário -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usuário"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/et_username"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="seu_usuario"
                android:inputType="textPersonName|textNoSuggestions"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_hint"
                android:background="@drawable/bg_input_field"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:maxLines="1"
                android:imeOptions="actionNext"
                android:nextFocusUp="@id/et_server_url"
                android:nextFocusDown="@+id/et_password"
                android:focusable="true"/>

            <Space android:layout_width="match_parent" android:layout_height="16dp"/>

            <!-- Campo: Senha -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Senha"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_hint"
                android:background="@drawable/bg_input_field"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:maxLines="1"
                android:imeOptions="actionDone"
                android:nextFocusUp="@id/et_username"
                android:nextFocusDown="@+id/btn_login"
                android:focusable="true"/>

            <Space android:layout_width="match_parent" android:layout_height="28dp"/>

            <!-- Botão Login -->
            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="ENTRAR"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/white"
                android:background="@drawable/bg_button_primary"
                android:nextFocusUp="@id/et_password"
                android:focusable="true"
                android:focusableInTouchMode="true"/>

            <!-- Loading overlay (visível durante a requisição) -->
            <ProgressBar
                android:id="@+id/progress_login"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:indeterminateTint="@color/accent_red"
                android:visibility="gone"/>

            <!-- Mensagem de erro -->
            <TextView
                android:id="@+id/tv_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/error_red"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
