<?xml version="1.0" encoding="utf-8"?>
<!--
    HomeActivity — container para o BrowseSupportFragment do Leanback.

    O BrowseSupportFragment renderiza:
      - Coluna esquerda: categorias (TV Aberta, Esportes, Filmes...)
      - Área direita:    grid horizontal de cards da categoria selecionada
      - Header superior: título do app + ações (busca, perfil)

    O fragment ocupa 100% da tela — não há UI adicional neste layout.
    Tudo (animações de foco, transições, scroll) é gerenciado pelo Leanback.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fragment_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"/>
