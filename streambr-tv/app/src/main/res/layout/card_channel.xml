<?xml version="1.0" encoding="utf-8"?>
<!--
    Card de canal ao vivo — usado no BrowseFragment (grid horizontal)

    Dimensões fixas obrigatórias em cards Leanback:
      Largura: 220dp  (padrão de card TV landscape)
      Altura:  130dp

    Estrutura visual:
      ┌─────────────────────┐
      │  [LOGO 64x64]       │  ← ImageView centralizado
      │                     │
      │  Nome do Canal      │  ← bold 15sp
      │  Grupo · Qualidade  │  ← 12sp muted
      │              [LIVE] │  ← badge vermelho (só canais ao vivo)
      └─────────────────────┘

    O seletor de foco (bg_card_focusable) escala o card para 1.08x
    e adiciona borda vermelha quando selecionado pelo D-pad.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="220dp"
    android:layout_height="130dp"
    app:cardCornerRadius="10dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardElevation="0dp"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:foreground="@drawable/bg_card_focusable">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="14dp">

        <!-- Logo do canal -->
        <ImageView
            android:id="@+id/iv_channel_logo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerInside"
            android:contentDescription="Logo do canal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_channel_name"/>

        <!-- Nome do canal -->
        <TextView
            android:id="@+id/tv_channel_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/iv_channel_logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_channel_group"/>

        <!-- Grupo + qualidade -->
        <TextView
            android:id="@+id/tv_channel_group"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="3dp"
            app:layout_constraintTop_toBottomOf="@id/tv_channel_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/badge_quality"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Badge qualidade (HD / 4K / FHD) -->
        <TextView
            android:id="@+id/badge_quality"
            android:layout_width="wrap_content"
            android:layout_height="18dp"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="@color/gold"
            android:background="@drawable/bg_badge_quality"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Badge LIVE pulsante (canto superior direito) -->
        <LinearLayout
            android:id="@+id/badge_live"
            android:layout_width="wrap_content"
            android:layout_height="18dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_badge_live"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:visibility="visible"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:id="@+id/dot_live"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:background="@drawable/shape_live_dot"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AO VIVO"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:letterSpacing="0.05"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
